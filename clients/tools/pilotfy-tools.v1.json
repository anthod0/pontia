{
  "$schema": "./agent-tools.v1.schema.json",
  "version": 1,
  "namespace": "pilotfy",
  "description": "Stable pilotfy DAG-mode tool definitions. Cross-language source of truth for tool names, input schemas, and output schemas.",
  "tools": [
    {
      "name": "getContext",
      "title": "Get DAG work context",
      "description": "Fetch the current DAG-managed context for the current session.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {}
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "planning",
              "execution"
            ],
            "description": "DAG context mode for the current session."
          },
          "task": {
            "type": "object",
            "description": "Current task view."
          },
          "dag": {
            "type": [
              "object",
              "null"
            ],
            "description": "DAG context data."
          },
          "work_item": {
            "type": [
              "object",
              "null"
            ],
            "description": "WorkItem context data."
          },
          "work_item_run": {
            "type": [
              "object",
              "null"
            ],
            "description": "WorkItemRun context data."
          },
          "signals": {
            "type": "array",
            "description": "Signal records.",
            "items": {
              "type": "object"
            }
          },
          "execution_profiles": {
            "type": "array",
            "description": "Execution profile records.",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "mode",
          "task"
        ]
      }
    },
    {
      "name": "submitPlan",
      "title": "Submit DAG proposal",
      "description": "Store a WorkItem DAG proposal or DAG patch proposal.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "initial_dag",
              "patch"
            ],
            "description": "Proposal kind."
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable summary of the proposed plan or patch."
          },
          "dag": {
            "type": "object",
            "description": "Initial DAG proposal payload.",
            "additionalProperties": false,
            "properties": {
              "work_items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "temp_id": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Temporary WorkItem ID for references in this proposal."
                    },
                    "title": {
                      "type": "string",
                      "minLength": 1
                    },
                    "description": {
                      "type": "string",
                      "minLength": 1
                    },
                    "kind": {
                      "type": "string",
                      "enum": [
                        "design",
                        "implementation",
                        "review",
                        "test",
                        "debug",
                        "documentation",
                        "planning",
                        "other"
                      ]
                    },
                    "action": {
                      "type": "string",
                      "enum": [
                        "agent_turn",
                        "human_input",
                        "noop"
                      ]
                    },
                    "execution_profile_id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "execution_profile_version": {
                      "type": "string"
                    },
                    "priority": {
                      "type": "integer",
                      "default": 0
                    },
                    "optional": {
                      "type": "boolean",
                      "default": false
                    },
                    "parallelizable": {
                      "type": "boolean",
                      "default": true
                    },
                    "acceptance_criteria": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "default": []
                    },
                    "metadata": {
                      "type": "object",
                      "additionalProperties": true,
                      "default": {}
                    }
                  },
                  "required": [
                    "temp_id",
                    "title",
                    "description",
                    "kind",
                    "action",
                    "execution_profile_id"
                  ]
                }
              },
              "edges": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "from_work_item_id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "to_work_item_id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "edge_type": {
                      "type": "string",
                      "enum": [
                        "depends_on"
                      ],
                      "default": "depends_on"
                    }
                  },
                  "required": [
                    "from_work_item_id",
                    "to_work_item_id"
                  ]
                },
                "default": []
              }
            },
            "required": [
              "work_items"
            ]
          },
          "patch": {
            "type": "object",
            "description": "DAG patch proposal payload.",
            "additionalProperties": false,
            "properties": {
              "anchor_work_item_id": {
                "type": "string",
                "minLength": 1,
                "description": "WorkItem ID used as the patch anchor."
              },
              "supersede_policy": {
                "type": "string",
                "enum": [
                  "none",
                  "explicit_only",
                  "direct_downstream",
                  "reachable_downstream"
                ],
                "default": "explicit_only",
                "description": "Patch supersede policy value."
              },
              "operations": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "op": {
                          "type": "string",
                          "const": "add_work_item"
                        },
                        "work_item": {
                          "type": "object",
                          "additionalProperties": false,
                          "properties": {
                            "temp_id": {
                              "type": "string",
                              "minLength": 1,
                              "description": "Temporary WorkItem ID for references in this proposal."
                            },
                            "title": {
                              "type": "string",
                              "minLength": 1
                            },
                            "description": {
                              "type": "string",
                              "minLength": 1
                            },
                            "kind": {
                              "type": "string",
                              "enum": [
                                "design",
                                "implementation",
                                "review",
                                "test",
                                "debug",
                                "documentation",
                                "planning",
                                "other"
                              ]
                            },
                            "action": {
                              "type": "string",
                              "enum": [
                                "agent_turn",
                                "human_input",
                                "noop"
                              ]
                            },
                            "execution_profile_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "execution_profile_version": {
                              "type": "string"
                            },
                            "priority": {
                              "type": "integer",
                              "default": 0
                            },
                            "optional": {
                              "type": "boolean",
                              "default": false
                            },
                            "parallelizable": {
                              "type": "boolean",
                              "default": true
                            },
                            "acceptance_criteria": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              },
                              "default": []
                            },
                            "metadata": {
                              "type": "object",
                              "additionalProperties": true,
                              "default": {}
                            }
                          },
                          "required": [
                            "temp_id",
                            "title",
                            "description",
                            "kind",
                            "action",
                            "execution_profile_id"
                          ]
                        }
                      },
                      "required": [
                        "op",
                        "work_item"
                      ]
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "op": {
                          "type": "string",
                          "const": "add_edge"
                        },
                        "edge": {
                          "type": "object",
                          "additionalProperties": false,
                          "properties": {
                            "from_work_item_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "to_work_item_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "edge_type": {
                              "type": "string",
                              "enum": [
                                "depends_on"
                              ],
                              "default": "depends_on"
                            }
                          },
                          "required": [
                            "from_work_item_id",
                            "to_work_item_id"
                          ]
                        }
                      },
                      "required": [
                        "op",
                        "edge"
                      ]
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "op": {
                          "type": "string",
                          "const": "set_work_item_outcome"
                        },
                        "work_item_id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "outcome_state": {
                          "type": "string",
                          "enum": [
                            "succeeded",
                            "failed",
                            "blocked",
                            "cancelled",
                            "partial",
                            "unknown"
                          ]
                        },
                        "reason": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "op",
                        "work_item_id",
                        "outcome_state",
                        "reason"
                      ]
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "op": {
                          "type": "string",
                          "const": "reactivate_work_item"
                        },
                        "work_item_id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "reason": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "op",
                        "work_item_id",
                        "reason"
                      ]
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "op": {
                          "type": "string",
                          "const": "replace_edge"
                        },
                        "from": {
                          "type": "object",
                          "additionalProperties": false,
                          "properties": {
                            "from_work_item_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "to_work_item_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "edge_type": {
                              "type": "string",
                              "enum": [
                                "depends_on"
                              ],
                              "default": "depends_on"
                            }
                          },
                          "required": [
                            "from_work_item_id",
                            "to_work_item_id"
                          ]
                        },
                        "to": {
                          "type": "object",
                          "additionalProperties": false,
                          "properties": {
                            "from_work_item_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "to_work_item_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "edge_type": {
                              "type": "string",
                              "enum": [
                                "depends_on"
                              ],
                              "default": "depends_on"
                            }
                          },
                          "required": [
                            "from_work_item_id",
                            "to_work_item_id"
                          ]
                        }
                      },
                      "required": [
                        "op",
                        "from",
                        "to"
                      ]
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "op": {
                          "type": "string",
                          "const": "remove_edge"
                        },
                        "edge": {
                          "type": "object",
                          "additionalProperties": false,
                          "properties": {
                            "from_work_item_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "to_work_item_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "edge_type": {
                              "type": "string",
                              "enum": [
                                "depends_on"
                              ],
                              "default": "depends_on"
                            }
                          },
                          "required": [
                            "from_work_item_id",
                            "to_work_item_id"
                          ]
                        }
                      },
                      "required": [
                        "op",
                        "edge"
                      ]
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "op": {
                          "type": "string",
                          "const": "supersede_work_item"
                        },
                        "work_item_id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "reason": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "op",
                        "work_item_id",
                        "reason"
                      ]
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "op": {
                          "type": "string",
                          "const": "insert_work_item_between"
                        },
                        "from_work_item_id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "to_work_item_id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "work_item": {
                          "type": "object",
                          "additionalProperties": false,
                          "properties": {
                            "temp_id": {
                              "type": "string",
                              "minLength": 1,
                              "description": "Temporary WorkItem ID for references in this proposal."
                            },
                            "title": {
                              "type": "string",
                              "minLength": 1
                            },
                            "description": {
                              "type": "string",
                              "minLength": 1
                            },
                            "kind": {
                              "type": "string",
                              "enum": [
                                "design",
                                "implementation",
                                "review",
                                "test",
                                "debug",
                                "documentation",
                                "planning",
                                "other"
                              ]
                            },
                            "action": {
                              "type": "string",
                              "enum": [
                                "agent_turn",
                                "human_input",
                                "noop"
                              ]
                            },
                            "execution_profile_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "execution_profile_version": {
                              "type": "string"
                            },
                            "priority": {
                              "type": "integer",
                              "default": 0
                            },
                            "optional": {
                              "type": "boolean",
                              "default": false
                            },
                            "parallelizable": {
                              "type": "boolean",
                              "default": true
                            },
                            "acceptance_criteria": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              },
                              "default": []
                            },
                            "metadata": {
                              "type": "object",
                              "additionalProperties": true,
                              "default": {}
                            }
                          },
                          "required": [
                            "temp_id",
                            "title",
                            "description",
                            "kind",
                            "action",
                            "execution_profile_id"
                          ]
                        }
                      },
                      "required": [
                        "op",
                        "from_work_item_id",
                        "to_work_item_id",
                        "work_item"
                      ]
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "op": {
                          "type": "string",
                          "const": "replace_downstream"
                        },
                        "anchor_work_item_id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "old_work_item_ids": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "minLength": 1
                          },
                          "minItems": 1
                        },
                        "replacement": {
                          "type": "object",
                          "additionalProperties": false,
                          "properties": {
                            "temp_id": {
                              "type": "string",
                              "minLength": 1,
                              "description": "Temporary WorkItem ID for references in this proposal."
                            },
                            "title": {
                              "type": "string",
                              "minLength": 1
                            },
                            "description": {
                              "type": "string",
                              "minLength": 1
                            },
                            "kind": {
                              "type": "string",
                              "enum": [
                                "design",
                                "implementation",
                                "review",
                                "test",
                                "debug",
                                "documentation",
                                "planning",
                                "other"
                              ]
                            },
                            "action": {
                              "type": "string",
                              "enum": [
                                "agent_turn",
                                "human_input",
                                "noop"
                              ]
                            },
                            "execution_profile_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "execution_profile_version": {
                              "type": "string"
                            },
                            "priority": {
                              "type": "integer",
                              "default": 0
                            },
                            "optional": {
                              "type": "boolean",
                              "default": false
                            },
                            "parallelizable": {
                              "type": "boolean",
                              "default": true
                            },
                            "acceptance_criteria": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              },
                              "default": []
                            },
                            "metadata": {
                              "type": "object",
                              "additionalProperties": true,
                              "default": {}
                            }
                          },
                          "required": [
                            "temp_id",
                            "title",
                            "description",
                            "kind",
                            "action",
                            "execution_profile_id"
                          ]
                        },
                        "supersede_old": {
                          "type": "boolean",
                          "default": true
                        }
                      },
                      "required": [
                        "op",
                        "anchor_work_item_id",
                        "old_work_item_ids",
                        "replacement"
                      ]
                    }
                  ]
                }
              },
              "base_revision": {
                "type": "integer",
                "description": "Optional optimistic concurrency revision for the DAG snapshot this patch was based on."
              }
            },
            "required": [
              "operations"
            ]
          },
          "assumptions": {
            "type": "array",
            "description": "Assumptions used while producing this plan.",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "risks": {
            "type": "array",
            "description": "Known risks in the proposed plan or patch.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "summary": {
                  "type": "string",
                  "minLength": 1
                },
                "severity": {
                  "type": "string",
                  "enum": [
                    "low",
                    "medium",
                    "high"
                  ]
                }
              },
              "required": [
                "summary"
              ]
            },
            "default": []
          }
        },
        "required": [
          "mode",
          "summary"
        ]
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "proposal_id": {
            "type": "string",
            "description": "Identifier of the stored DAG proposal or patch proposal."
          },
          "validation": {
            "type": "object",
            "description": "Validation result or diagnostics."
          },
          "apply": {
            "type": "object",
            "description": "Apply result data."
          },
          "scheduler": {
            "type": "object",
            "description": "Additional result data."
          }
        },
        "required": [
          "proposal_id",
          "validation",
          "apply",
          "scheduler"
        ]
      }
    },
    {
      "name": "applyPlan",
      "title": "Apply DAG proposal",
      "description": "Apply a stored DAG proposal by proposal ID.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "proposal_id": {
            "type": "string",
            "minLength": 1,
            "description": "Stored proposal identifier."
          },
          "approval_quote": {
            "type": "string",
            "description": "Approval message text."
          },
          "approval_message_ref": {
            "type": "string",
            "description": "Approval reference identifier."
          }
        },
        "required": [
          "proposal_id"
        ]
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "proposal_id": {
            "type": "string",
            "description": "Identifier of the stored DAG proposal or patch proposal."
          },
          "validation": {
            "type": "object",
            "description": "Validation result or diagnostics."
          },
          "apply": {
            "type": "object",
            "description": "Apply result data."
          },
          "scheduler": {
            "type": "object",
            "description": "Additional result data."
          }
        },
        "required": [
          "proposal_id",
          "validation",
          "apply",
          "scheduler"
        ]
      }
    },
    {
      "name": "submitResult",
      "title": "Submit WorkItem result",
      "description": "Store a WorkItemRun result.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "completed",
              "failed",
              "blocked",
              "needs_input"
            ],
            "description": "Outcome for the current WorkItemRun."
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable result summary."
          },
          "outputs": {
            "type": "array",
            "description": "Logical work products produced or identified by this run.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "patch",
                    "document",
                    "test_report",
                    "review_report",
                    "finding",
                    "other"
                  ]
                },
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "summary": {
                  "type": "string"
                },
                "ref": {
                  "type": "string",
                  "description": "Optional external reference such as artifact:<id>, file:<path>, event:<id>, or URL."
                }
              },
              "required": [
                "kind",
                "name"
              ]
            },
            "default": []
          },
          "failure": {
            "type": "object",
            "description": "Failure or blocking detail.",
            "additionalProperties": false,
            "properties": {
              "reason": {
                "type": "string",
                "minLength": 1
              },
              "retryable": {
                "type": "boolean"
              }
            },
            "required": [
              "reason"
            ]
          }
        },
        "required": [
          "status",
          "summary"
        ]
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "accepted": {
            "type": "boolean",
            "description": "Whether pilotfy accepted the result for the current WorkItemRun."
          },
          "work_item_run": {
            "type": "object",
            "description": "Updated WorkItemRun view or summary."
          }
        },
        "required": [
          "accepted"
        ]
      }
    },
    {
      "name": "raiseSignal",
      "title": "Raise DAG signal",
      "description": "Store a DAG signal record.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "needs_input",
              "replan_requested",
              "risk",
              "missing_dependency",
              "scope_change",
              "assistance_needed",
              "review_requested",
              "other"
            ],
            "description": "Signal category."
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "description": "Short signal summary."
          },
          "detail": {
            "type": "string",
            "description": "Detailed explanation, question, or evidence."
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "default": "medium"
          },
          "related_refs": {
            "type": "array",
