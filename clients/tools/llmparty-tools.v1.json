{
  "$schema": "./agent-tools.v1.schema.json",
  "version": 1,
  "namespace": "llmparty",
  "description": "Stable llmparty DAG-mode agent tool definitions. This file is the cross-language source of truth for tool names, descriptions, input schemas, and output schemas. All DAG agents may register the same tools; llmparty authorizes each call server-side from the current session, execution profile, task, WorkItem, and WorkItemRun context.",
  "tools": [
    {
      "name": "getContext",
      "title": "Get DAG work context",
      "description": "Fetch the current DAG-managed context for this agent session. Planning agents receive task, DAG, signals, workspace summary, and available execution profile context. Execution agents receive the current WorkItemRun, inputs, dependencies, expected outputs, and acceptance criteria. The caller must not provide task, WorkItem, run, or profile identity; llmparty derives it from the current session.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {}
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "planning",
              "execution"
            ],
            "description": "Authorized DAG agent mode for the current session."
          },
          "task": {
            "type": "object",
            "description": "Current task view."
          },
          "dag": {
            "type": [
              "object",
              "null"
            ],
            "description": "Current approved or draft DAG context when relevant."
          },
          "work_item": {
            "type": [
              "object",
              "null"
            ],
            "description": "Current WorkItem context for execution agents."
          },
          "work_item_run": {
            "type": [
              "object",
              "null"
            ],
            "description": "Current WorkItemRun context for execution agents."
          },
          "signals": {
            "type": "array",
            "description": "Relevant signals for planning or execution.",
            "items": {
              "type": "object"
            }
          },
          "execution_profiles": {
            "type": "array",
            "description": "Relevant available execution profiles for planning agents.",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "mode",
          "task"
        ]
      }
    },
    {
      "name": "submitPlan",
      "title": "Submit DAG plan",
      "description": "Submit the planning agent's main output: an initial WorkItem DAG proposal or a DAG patch proposal. This tool proposes structured plan changes only; it does not approve, apply, or schedule the DAG. llmparty validates and authorizes the proposal server-side based on the current planning session and execution profile.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "initial_dag",
              "patch"
            ],
            "description": "Whether this submission proposes the initial DAG or a patch to an existing DAG."
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable summary of the proposed plan or patch."
          },
          "dag": {
            "type": "object",
            "description": "Initial DAG proposal when mode is initial_dag. Temporary WorkItem IDs are allowed; llmparty assigns authoritative IDs when applying an approved DAG.",
            "additionalProperties": false,
            "properties": {
              "work_items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "temp_id": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Temporary WorkItem ID for references in this proposal."
                    },
                    "title": {
                      "type": "string",
                      "minLength": 1
                    },
                    "description": {
                      "type": "string",
                      "minLength": 1
                    },
                    "kind": {
                      "type": "string",
                      "enum": [
                        "design",
                        "implementation",
                        "review",
                        "test",
                        "debug",
                        "documentation",
                        "planning",
                        "other"
                      ]
                    },
                    "action": {
                      "type": "string",
                      "enum": [
                        "agent_turn",
                        "human_input",
                        "noop"
                      ]
                    },
                    "execution_profile_id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "execution_profile_version": {
                      "type": "string"
                    },
                    "priority": {
                      "type": "integer",
                      "default": 0
                    },
                    "optional": {
                      "type": "boolean",
                      "default": false
                    },
                    "parallelizable": {
                      "type": "boolean",
                      "default": true
                    },
                    "acceptance_criteria": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "default": []
                    },
                    "metadata": {
                      "type": "object",
                      "additionalProperties": true,
                      "default": {}
                    }
                  },
                  "required": [
                    "temp_id",
                    "title",
                    "description",
                    "kind",
                    "action",
                    "execution_profile_id"
                  ]
                }
              },
              "edges": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "from_work_item_id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "to_work_item_id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "edge_type": {
                      "type": "string",
                      "enum": [
                        "depends_on"
                      ],
                      "default": "depends_on"
                    }
                  },
                  "required": [
                    "from_work_item_id",
                    "to_work_item_id"
                  ]
                },
                "default": []
              }
            },
            "required": [
              "work_items"
            ]
          },
          "patch": {
            "type": "object",
            "description": "DAG patch proposal when mode is patch. Supported operations are validated by llmparty before approval or application.",
            "additionalProperties": false,
            "properties": {
              "anchor_work_item_id": {
                "type": "string",
                "minLength": 1,
                "description": "Existing WorkItem that anchors an automatic cutover. Required for direct_downstream or reachable_downstream supersede policies."
              },
              "supersede_policy": {
                "type": "string",
                "enum": [
                  "none",
                  "explicit_only",
                  "direct_downstream",
                  "reachable_downstream"
                ],
                "default": "explicit_only",
                "description": "Controls which existing active WorkItems are automatically superseded before adding patch operations. reachable_downstream replaces the old active path after anchor_work_item_id."
              },
              "operations": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "op": {
                          "type": "string",
                          "const": "add_work_item"
                        },
                        "work_item": {
                          "type": "object",
                          "additionalProperties": false,
                          "properties": {
                            "temp_id": {
                              "type": "string",
                              "minLength": 1,
                              "description": "Temporary WorkItem ID for references in this proposal."
                            },
                            "title": {
                              "type": "string",
                              "minLength": 1
                            },
                            "description": {
                              "type": "string",
                              "minLength": 1
                            },
                            "kind": {
                              "type": "string",
                              "enum": [
                                "design",
                                "implementation",
                                "review",
                                "test",
                                "debug",
                                "documentation",
                                "planning",
                                "other"
                              ]
                            },
                            "action": {
                              "type": "string",
                              "enum": [
                                "agent_turn",
                                "human_input",
                                "noop"
                              ]
                            },
                            "execution_profile_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "execution_profile_version": {
                              "type": "string"
                            },
                            "priority": {
                              "type": "integer",
                              "default": 0
                            },
                            "optional": {
                              "type": "boolean",
                              "default": false
                            },
                            "parallelizable": {
                              "type": "boolean",
                              "default": true
                            },
                            "acceptance_criteria": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              },
                              "default": []
                            },
                            "metadata": {
                              "type": "object",
                              "additionalProperties": true,
                              "default": {}
                            }
                          },
                          "required": [
                            "temp_id",
                            "title",
                            "description",
                            "kind",
                            "action",
                            "execution_profile_id"
                          ]
                        }
                      },
                      "required": [
                        "op",
                        "work_item"
                      ]
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "op": {
                          "type": "string",
                          "const": "add_edge"
                        },
                        "edge": {
                          "type": "object",
                          "additionalProperties": false,
                          "properties": {
                            "from_work_item_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "to_work_item_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "edge_type": {
                              "type": "string",
                              "enum": [
                                "depends_on"
                              ],
                              "default": "depends_on"
                            }
                          },
                          "required": [
                            "from_work_item_id",
                            "to_work_item_id"
                          ]
                        }
                      },
                      "required": [
                        "op",
                        "edge"
                      ]
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "op": {
                          "type": "string",
                          "const": "set_work_item_outcome"
                        },
                        "work_item_id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "outcome_state": {
                          "type": "string",
                          "enum": [
                            "succeeded",
                            "failed",
                            "blocked",
                            "cancelled",
                            "partial",
                            "unknown"
                          ]
                        },
                        "reason": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "op",
                        "work_item_id",
                        "outcome_state",
                        "reason"
                      ]
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "op": {
                          "type": "string",
                          "const": "reactivate_work_item"
                        },
                        "work_item_id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "reason": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "op",
                        "work_item_id",
                        "reason"
                      ]
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "op": {
                          "type": "string",
                          "const": "replace_edge"
                        },
                        "from": {
                          "type": "object",
                          "additionalProperties": false,
                          "properties": {
                            "from_work_item_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "to_work_item_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "edge_type": {
                              "type": "string",
                              "enum": [
                                "depends_on"
                              ],
                              "default": "depends_on"
                            }
                          },
                          "required": [
                            "from_work_item_id",
                            "to_work_item_id"
                          ]
                        },
                        "to": {
                          "type": "object",
                          "additionalProperties": false,
                          "properties": {
                            "from_work_item_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "to_work_item_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "edge_type": {
                              "type": "string",
                              "enum": [
                                "depends_on"
                              ],
                              "default": "depends_on"
                            }
                          },
                          "required": [
                            "from_work_item_id",
                            "to_work_item_id"
                          ]
                        }
                      },
                      "required": [
                        "op",
                        "from",
                        "to"
                      ]
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "op": {
                          "type": "string",
                          "const": "remove_edge"
                        },
                        "edge": {
                          "type": "object",
                          "additionalProperties": false,
                          "properties": {
                            "from_work_item_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "to_work_item_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "edge_type": {
                              "type": "string",
                              "enum": [
                                "depends_on"
                              ],
                              "default": "depends_on"
                            }
                          },
                          "required": [
                            "from_work_item_id",
                            "to_work_item_id"
                          ]
                        }
                      },
                      "required": [
                        "op",
                        "edge"
                      ]
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "op": {
                          "type": "string",
                          "const": "supersede_work_item"
                        },
                        "work_item_id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "reason": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "op",
                        "work_item_id",
                        "reason"
                      ]
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "op": {
                          "type": "string",
                          "const": "insert_work_item_between"
                        },
                        "from_work_item_id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "to_work_item_id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "work_item": {
                          "type": "object",
                          "additionalProperties": false,
                          "properties": {
                            "temp_id": {
                              "type": "string",
                              "minLength": 1,
                              "description": "Temporary WorkItem ID for references in this proposal."
                            },
                            "title": {
                              "type": "string",
                              "minLength": 1
                            },
                            "description": {
                              "type": "string",
                              "minLength": 1
                            },
                            "kind": {
                              "type": "string",
                              "enum": [
                                "design",
                                "implementation",
                                "review",
                                "test",
                                "debug",
                                "documentation",
                                "planning",
                                "other"
                              ]
                            },
                            "action": {
                              "type": "string",
                              "enum": [
                                "agent_turn",
                                "human_input",
                                "noop"
                              ]
                            },
                            "execution_profile_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "execution_profile_version": {
                              "type": "string"
                            },
                            "priority": {
                              "type": "integer",
                              "default": 0
                            },
                            "optional": {
                              "type": "boolean",
                              "default": false
                            },
                            "parallelizable": {
                              "type": "boolean",
                              "default": true
                            },
                            "acceptance_criteria": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              },
                              "default": []
                            },
                            "metadata": {
                              "type": "object",
                              "additionalProperties": true,
                              "default": {}
                            }
                          },
                          "required": [
                            "temp_id",
                            "title",
                            "description",
                            "kind",
                            "action",
                            "execution_profile_id"
                          ]
                        }
                      },
                      "required": [
                        "op",
                        "from_work_item_id",
                        "to_work_item_id",
                        "work_item"
                      ]
                    },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "op": {
                          "type": "string",
                          "const": "replace_downstream"
                        },
                        "anchor_work_item_id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "old_work_item_ids": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "minLength": 1
                          },
                          "minItems": 1
                        },
                        "replacement": {
                          "type": "object",
                          "additionalProperties": false,
                          "properties": {
                            "temp_id": {
                              "type": "string",
                              "minLength": 1,
                              "description": "Temporary WorkItem ID for references in this proposal."
                            },
                            "title": {
                              "type": "string",
                              "minLength": 1
                            },
                            "description": {
                              "type": "string",
                              "minLength": 1
                            },
                            "kind": {
                              "type": "string",
                              "enum": [
                                "design",
                                "implementation",
                                "review",
                                "test",
                                "debug",
                                "documentation",
                                "planning",
                                "other"
                              ]
                            },
                            "action": {
                              "type": "string",
                              "enum": [
                                "agent_turn",
                                "human_input",
                                "noop"
                              ]
                            },
                            "execution_profile_id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "execution_profile_version": {
                              "type": "string"
                            },
                            "priority": {
                              "type": "integer",
                              "default": 0
                            },
                            "optional": {
                              "type": "boolean",
                              "default": false
                            },
                            "parallelizable": {
                              "type": "boolean",
                              "default": true
                            },
                            "acceptance_criteria": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              },
                              "default": []
                            },
                            "metadata": {
                              "type": "object",
                              "additionalProperties": true,
                              "default": {}
                            }
                          },
                          "required": [
                            "temp_id",
                            "title",
                            "description",
                            "kind",
                            "action",
                            "execution_profile_id"
                          ]
                        },
                        "supersede_old": {
                          "type": "boolean",
                          "default": true
                        }
                      },
                      "required": [
                        "op",
                        "anchor_work_item_id",
                        "old_work_item_ids",
                        "replacement"
                      ]
                    }
                  ]
                }
              },
              "base_revision": {
                "type": "integer",
                "description": "Optional optimistic concurrency revision for the DAG snapshot this patch was based on."
              }
            },
            "required": [
              "operations"
            ]
          },
          "assumptions": {
            "type": "array",
            "description": "Assumptions used while producing this plan.",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "risks": {
            "type": "array",
            "description": "Known risks in the proposed plan or patch.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "summary": {
                  "type": "string",
                  "minLength": 1
                },
                "severity": {
                  "type": "string",
                  "enum": [
                    "low",
                    "medium",
                    "high"
                  ]
                }
              },
              "required": [
                "summary"
              ]
            },
            "default": []
          }
        },
        "required": [
          "mode",
          "summary"
        ]
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "proposal_id": {
            "type": "string",
            "description": "Identifier of the stored DAG proposal or patch proposal."
          },
          "validation": {
            "type": "object",
            "description": "Validation result or diagnostics."
          },
          "apply": {
            "type": "object",
            "description": "Apply outcome for the proposal."
          },
          "scheduler": {
            "type": "object",
            "description": "Scheduler outcome after applying the proposal."
          }
        },
        "required": [
          "proposal_id",
          "validation",
          "apply",
          "scheduler"
        ]
      }
    },
    {
      "name": "applyPlan",
      "title": "Apply approved DAG plan",
      "description": "Apply a previously submitted DAG proposal after the user has approved it in the planning chat. This promotes the single stored draft proposal into the executable DAG and starts scheduling.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "proposal_id": {
            "type": "string",
            "minLength": 1,
            "description": "Identifier returned by submitPlan for the proposal the user approved."
          },
          "approval_quote": {
            "type": "string",
            "description": "Short quote of the user chat message that explicitly approved applying this proposal."
          },
          "approval_message_ref": {
            "type": "string",
            "description": "Optional stable reference to the user message that approved this proposal."
          }
        },
        "required": [
          "proposal_id"
        ]
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "proposal_id": {
            "type": "string",
            "description": "Identifier of the stored DAG proposal or patch proposal."
          },
          "validation": {
            "type": "object",
            "description": "Validation result or diagnostics."
          },
          "apply": {
            "type": "object",
            "description": "Apply outcome for the proposal."
          },
          "scheduler": {
            "type": "object",
            "description": "Scheduler outcome after applying the proposal."
          }
        },
        "required": [
          "proposal_id",
          "validation",
          "apply",
          "scheduler"
        ]
      }
    },
    {
      "name": "submitResult",
      "title": "Submit WorkItem result",
      "description": "Submit the execution agent's main output for the current WorkItemRun. Implementation, validation, review, documentation, debugging, and similar WorkItems all use this same tool. This tool reports the current node result only; llmparty decides scheduling, retry, session reuse, and downstream DAG state server-side.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "completed",
              "failed",
              "blocked",
              "needs_input"
            ],
            "description": "Outcome for the current WorkItemRun."
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable result summary."
          },
          "outputs": {
            "type": "array",
            "description": "Logical work products produced or identified by this run. These may reference runtime artifacts or workspace files, but do not directly mutate the DAG.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "patch",
                    "document",
                    "test_report",
                    "review_report",
                    "finding",
                    "other"
                  ]
                },
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "summary": {
                  "type": "string"
                },
                "ref": {
                  "type": "string",
                  "description": "Optional external reference such as artifact:<id>, file:<path>, event:<id>, or URL."
                }
              },
              "required": [
                "kind",
                "name"
              ]
            },
            "default": []
          },
          "failure": {
            "type": "object",
            "description": "Failure or blocking detail when status is failed, blocked, or needs_input.",
            "additionalProperties": false,
            "properties": {
              "reason": {
                "type": "string",
                "minLength": 1
              },
              "retryable": {
                "type": "boolean"
              }
            },
            "required": [
              "reason"
            ]
          }
        },
        "required": [
          "status",
          "summary"
        ]
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "accepted": {
