{
  "llmparty_plugin_version": 1,
  "client_type": "pi",
  "kind": "pi-extension",
  "distribution": {
    "type": "npm",
    "package": "@llmparty/pi-client-plugin"
  },
  "entry": "./src/index.ts",
  "capabilities": {
    "report_turn_started": false,
    "report_turn_finished": true,
    "stream_output": true,
    "artifact_sources": false
  },
  "requires": {
    "env": [
      "LLMPARTY_SESSION_ID",
      "LLMPARTY_RUNTIME_INSTANCE_ID",
      "LLMPARTY_CURRENT_TURN_FILE",
      "LLMPARTY_INTERNAL_EVENT_URL"
    ]
  }
}
