# Local development defaults. Environment variables take precedence over config.toml.
# TOML config is loaded from ~/.config/llmparty/config.toml by default,
# or from LLMPARTY_CONFIG / `llmparty --config <path>`.
LLMPARTY_BIND_ADDR=127.0.0.1:8080
LLMPARTY_DATABASE_URL=sqlite://~/.local/share/llmparty/llmparty.db
# Set for External API milestones; unused by /healthz in M0.
LLMPARTY_EXTERNAL_API_TOKEN=dev-token
LLMPARTY_RUN_MIGRATIONS=true
# URL injected into pi runtime/hook context for reporting turn facts.
LLMPARTY_INTERNAL_EVENT_URL=http://127.0.0.1:8080/internal/v1/events
