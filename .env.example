# Local development defaults. Environment variables take precedence over config.toml.
# TOML config is loaded from ~/.config/pilotfy/config.toml by default,
# or from PILOTFY_CONFIG / `pilotfy --config <path>`.
PILOTFY_BIND_ADDR=127.0.0.1:8080
PILOTFY_DATABASE_URL=sqlite://~/.local/share/pilotfy/pilotfy.db
# Set for External API milestones; unused by /healthz in M0.
PILOTFY_EXTERNAL_API_TOKEN=dev-token
PILOTFY_RUN_MIGRATIONS=true
# URL injected into pi runtime/hook context for reporting turn facts.
PILOTFY_INTERNAL_EVENT_URL=http://127.0.0.1:8080/internal/v1/events
