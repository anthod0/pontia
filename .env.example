# Local development defaults. Environment variables take precedence over config.toml.
# TOML config is loaded from ${PONTIA_HOME:-$HOME/.pontia}/config.toml by default,
# or from PONTIA_CONFIG / `pontia --config <path>`.
# PONTIA_HOME=$HOME/.pontia
PONTIA_BIND_ADDR=127.0.0.1:8080
PONTIA_DATABASE_URL=sqlite://~/.pontia/data/pontia.db
# Set for External API milestones; unused by /healthz in M0.
PONTIA_EXTERNAL_API_TOKEN=dev-token
PONTIA_RUN_MIGRATIONS=true
# URL injected into pi runtime/hook context for reporting turn facts.
PONTIA_INTERNAL_EVENT_URL=http://127.0.0.1:8080/internal/v1/events
